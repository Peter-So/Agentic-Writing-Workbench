# Copy this file to .env.shared and fill in your own endpoints and keys.

# Runtime sidecars are optional. Leave CHROMA_URL and EMBEDDING_URL blank to disable
# vector search and use local TF-IDF / fallback corpus behavior.
# Example when using an SSH tunnel:
#   ssh -L 8000:127.0.0.1:8000 -L 8001:127.0.0.1:8001 <user@your-sidecar-host>
#   CHROMA_URL=http://127.0.0.1:8000
#   EMBEDDING_URL=http://127.0.0.1:8001/embed
CHROMA_URL=
EMBEDDING_URL=
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database

# Text model registry
LLM_KEYS=deepseek,gpt,claude

LLM_DEEPSEEK_NAME=DeepSeek
LLM_DEEPSEEK_MODEL=
LLM_DEEPSEEK_BASE_URL=
LLM_DEEPSEEK_API_KEY=

LLM_GPT_NAME=GPT
LLM_GPT_MODEL=
LLM_GPT_BASE_URL=
LLM_GPT_API_KEY=

LLM_CLAUDE_NAME=Claude
LLM_CLAUDE_MODEL=
LLM_CLAUDE_BASE_URL=
LLM_CLAUDE_API_KEY=

LLM_ROLE_CHAT=gpt
LLM_ROLE_WRITING=claude
LLM_ROLE_REVIEW=gpt

# Image model registry
IMAGE_LLM_KEYS=gpt_image

IMAGE_LLM_GPT_IMAGE_NAME=GPT Image
IMAGE_LLM_GPT_IMAGE_MODEL=
IMAGE_LLM_GPT_IMAGE_BASE_URL=
IMAGE_LLM_GPT_IMAGE_API_KEY=
IMAGE_LLM_GPT_IMAGE_API_FORMAT=openai-image
IMAGE_LLM_GPT_IMAGE_API_PATH=/v1/images/generations
IMAGE_LLM_GPT_IMAGE_OPENAI_SIZE=1536x1024
IMAGE_LLM_GPT_IMAGE_MAX_PROMPT_CHARS=1200
IMAGE_LLM_GPT_IMAGE_ASPECT_RATIO=16:9
IMAGE_LLM_GPT_IMAGE_SIZE=1K
IMAGE_LLM_ROLE_IMAGE=gpt_image
